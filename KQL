# Azure Firewall Log Analytics Queries for Storage Account Replication

## Query 1: Basic Firewall Logs with IP Filtering

```kql
// Replace the IP addresses in the arrays below with your actual source and destination IPs
let sourceIPs = dynamic(["10.1.0.10", "10.1.0.11", "10.1.0.12"]);
let destIPs = dynamic(["10.2.0.10", "10.2.0.11", "10.2.0.12"]);
let timeRange = 24h;  // Adjust as needed

AzureDiagnostics
| where ResourceType == "AZUREFIREWALLS"
| where TimeGenerated >= ago(timeRange)
| where Category in ("AzureFirewallApplicationRule", "AzureFirewallNetworkRule")
| extend SourceIP = extract(@"Source: ([0-9\.]+)", 1, msg_s)
| extend DestIP = extract(@"Destination: ([0-9\.]+)", 1, msg_s)
| extend DestPort = extract(@"Destination Port: ([0-9]+)", 1, msg_s)
| extend Protocol = extract(@"Proto: ([A-Z]+)", 1, msg_s)
| extend Action = extract(@"Action: ([A-Z]+)", 1, msg_s)
| extend URL = extract(@"Url: ([^\s]+)", 1, msg_s)
| where SourceIP in (sourceIPs) or DestIP in (destIPs)
| project TimeGenerated, SourceIP, DestIP, DestPort, Protocol, Action, URL, msg_s
| order by TimeGenerated desc
```

## Query 2: Storage-Specific Traffic Analysis

```kql
// Focus on storage-related ports (443, 445, 3260)
let sourceIPs = dynamic(["10.1.0.10", "10.1.0.11", "10.1.0.12"]);
let destIPs = dynamic(["10.2.0.10", "10.2.0.11", "10.2.0.12"]);
let storagePorts = dynamic(["443", "445", "3260"]);
let timeRange = 24h;

AzureDiagnostics
| where ResourceType == "AZUREFIREWALLS"
| where TimeGenerated >= ago(timeRange)
| where Category in ("AzureFirewallApplicationRule", "AzureFirewallNetworkRule")
| extend SourceIP = extract(@"Source: ([0-9\.]+)", 1, msg_s)
| extend DestIP = extract(@"Destination: ([0-9\.]+)", 1, msg_s)
| extend DestPort = extract(@"Destination Port: ([0-9]+)", 1, msg_s)
| extend Protocol = extract(@"Proto: ([A-Z]+)", 1, msg_s)
| extend Action = extract(@"Action: ([A-Z]+)", 1, msg_s)
| where (SourceIP in (sourceIPs) or DestIP in (destIPs))
| where DestPort in (storagePorts) or msg_s contains "blob.core.windows.net" 
    or msg_s contains "file.core.windows.net"
| project TimeGenerated, SourceIP, DestIP, DestPort, Protocol, Action, msg_s
| order by TimeGenerated desc
```

## Query 3: Connection Summary with Statistics

```kql
let sourceIPs = dynamic(["10.1.0.10", "10.1.0.11", "10.1.0.12"]);
let destIPs = dynamic(["10.2.0.10", "10.2.0.11", "10.2.0.12"]);
let timeRange = 24h;

AzureDiagnostics
| where ResourceType == "AZUREFIREWALLS"
| where TimeGenerated >= ago(timeRange)
| where Category in ("AzureFirewallApplicationRule", "AzureFirewallNetworkRule")
| extend SourceIP = extract(@"Source: ([0-9\.]+)", 1, msg_s)
| extend DestIP = extract(@"Destination: ([0-9\.]+)", 1, msg_s)
| extend DestPort = extract(@"Destination Port: ([0-9]+)", 1, msg_s)
| extend Protocol = extract(@"Proto: ([A-Z]+)", 1, msg_s)
| extend Action = extract(@"Action: ([A-Z]+)", 1, msg_s)
| where SourceIP in (sourceIPs) or DestIP in (destIPs)
| summarize 
    ConnectionCount = count(),
    UniqueDestPorts = make_set(DestPort),
    UniqueProtocols = make_set(Protocol),
    AllowedConnections = countif(Action == "Allow"),
    DeniedConnections = countif(Action == "Deny"),
    FirstSeen = min(TimeGenerated),
    LastSeen = max(TimeGenerated)
    by SourceIP, DestIP
| order by ConnectionCount desc
```

## Query 4: Traffic Volume by Port (for Storage Replication Analysis)

```kql
let sourceIPs = dynamic(["10.1.0.10", "10.1.0.11", "10.1.0.12"]);
let destIPs = dynamic(["10.2.0.10", "10.2.0.11", "10.2.0.12"]);
