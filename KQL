## Query 6: Detailed Message Analysis (URLs and FQDNs)

```kql
let sourceIPs = dynamic(["10.1.0.10", "10.1.0.11", "10.1.0.12"]);
let destIPs = dynamic(["10.2.0.10", "10.2.0.11", "10.2.0.12"]);
let timeRange = 24h;

AzureDiagnostics
| where ResourceType == "AZUREFIREWALLS"
| where TimeGenerated >= ago(timeRange)
| where Category == "AzureFirewallApplicationRule"
| extend SourceIP = extract(@"Source: ([0-9\.]+)", 1, msg_s)
| extend DestIP = extract(@"Destination: ([0-9\.]+)", 1, msg_s)
| extend FQDN = extract(@"FQDN: ([^\s]+)", 1, msg_s)
| extend URL = extract(@"Url: ([^\s]+)", 1, msg_s)
| extend Action = extract(@"Action: ([A-Z]+)", 1, msg_s)
| where SourceIP in (sourceIPs) or DestIP in (destIPs)
| where FQDN contains "blob.core.windows.net" 
    or FQDN contains "file.core.windows.net"
    or FQDN contains "queue.core.windows.net"
    or FQDN contains "table.core.windows.net"
| project TimeGenerated, SourceIP, FQDN, URL, Action
| order by TimeGenerated desc
```

