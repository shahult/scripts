#!/bin/bash
# ============================================================
# create_acr_private_endpoints.sh
# Creates private endpoints for Azure Container Registries
# defined in a CSV file.
#
# CSV Format (with header row):
#   acr_name,acr_resource_group,source_subscription_id
#
# Usage:
#   ./create_acr_private_endpoints.sh \
#     --csv acr_list.csv \
#     --dest-rg /subscriptions/<sub-id>/resourceGroups/<rg-name> \
#     --dns-zone-id /subscriptions/<sub-id>/resourceGroups/<rg-name>/providers/Microsoft.Network/privateDnsZones/privatelink.azurecr.io \
#     --subnet-id /subscriptions/<sub-id>/resourceGroups/<rg-name>/providers/Microsoft.Network/virtualNetworks/<vnet>/subnets/<subnet>
# ============================================================

set -euo pipefail

# ---------- Defaults ----------
LOCATION="switzerlandnorth"
LOG_FILE="acr_pe_$(date +%Y%m%d_%H%M%S).log"

# ---------- Colours ----------
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; NC='\033[0m'

log()    { echo -e "[$(date '+%H:%M:%S')] $*" | tee -a "$LOG_FILE"; }
ok()     { log "${GREEN}[OK]${NC}    $*"; }
warn()   { log "${YELLOW}[WARN]${NC}  $*"; }
err()    { log "${RED}[ERROR]${NC} $*"; }

usage() {
  cat <<EOF
Usage: $0 --csv <file> --dest-rg <resource-group-id> --dns-zone-id <dns-zone-id> --subnet-id <subnet-id>

Required:
  --csv          Path to the CSV file (see format above)
  --dest-rg      Full resource ID of the destination resource group
                   e.g. /subscriptions/xxx/resourceGroups/my-pe-rg
  --dns-zone-id  Full resource ID of the Private DNS Zone
                   e.g. /subscriptions/xxx/resourceGroups/dns-rg/providers/
                        Microsoft.Network/privateDnsZones/privatelink.azurecr.io
  --subnet-id    Full resource ID of the subnet for the private endpoint
                   e.g. /subscriptions/xxx/resourceGroups/net-rg/providers/
                        Microsoft.Network/virtualNetworks/my-vnet/subnets/pe-subnet

Optional:
  --location     Azure region (default: switzerlandnorth)
  --dry-run      Print commands without executing them
  -h, --help     Show this help
EOF
  exit 0
}

# ---------- Argument parsing ----------
CSV_FILE=""; DEST_RG_ID=""; DNS_ZONE_ID=""; SUBNET_ID=""; DRY_RUN=false

while [[ $# -gt 0 ]]; do
  case $1 in
    --csv)          CSV_FILE="$2";      shift 2 ;;
    --dest-rg)      DEST_RG_ID="$2";   shift 2 ;;
    --dns-zone-id)  DNS_ZONE_ID="$2";  shift 2 ;;
    --subnet-id)    SUBNET_ID="$2";    shift 2 ;;
    --location)     LOCATION="$2";     shift 2 ;;
    --dry-run)      DRY_RUN=true;      shift   ;;
    -h|--help)      usage ;;
    *) err "Unknown argument: $1"; usage ;;
  esac
done

# ---------- Validate required args ----------
for var in CSV_FILE DEST_RG_ID DNS_ZONE_ID SUBNET_ID; do
  [[ -z "${!var}" ]] && { err "--${var//_/-} is required."; usage; }
done
[[ -f "$CSV_FILE" ]] || { err "CSV file not found: $CSV_FILE"; exit 1; }

# ---------- Parse destination resource group name ----------
DEST_RG_NAME=$(basename "$DEST_RG_ID")
DEST_SUBSCRIPTION=$(echo "$DEST_RG_ID" | cut -d'/' -f3)

log "======================================================"
log " ACR Private Endpoint Creation Script"
log "======================================================"
log " CSV file       : $CSV_FILE"
log " Dest RG        : $DEST_RG_NAME (sub: $DEST_SUBSCRIPTION)"
log " Location       : $LOCATION"
log " DNS Zone       : $DNS_ZONE_ID"
log " Subnet         : $SUBNET_ID"
log " Dry run        : $DRY_RUN"
log "======================================================"

# ---------- Helper: run or print ----------
run() {
  if $DRY_RUN; then
    log "[DRY-RUN] $*"
  else
    eval "$@"
  fi
}

# ---------- Counters ----------
TOTAL=0; SUCCESS=0; FAILED=0; SKIPPED=0

# ---------- Process CSV ----------
# Strip Windows line endings; skip header; skip blank/comment lines
tail -n +2 "$CSV_FILE" | tr -d '\r' | while IFS=',' read -r ACR_NAME ACR_RG SOURCE_SUB; do

  # Skip blank lines or comment lines
  [[ -z "$ACR_NAME" || "$ACR_NAME" == \#* ]] && continue

  # Trim whitespace
  ACR_NAME=$(echo "$ACR_NAME" | xargs)
  ACR_RG=$(echo "$ACR_RG"    | xargs)
  SOURCE_SUB=$(echo "$SOURCE_SUB" | xargs)

  TOTAL=$((TOTAL + 1))
  PE_NAME="pe-${ACR_NAME}"
  CONN_NAME="conn-${ACR_NAME}"

  log "------------------------------------------------------"
  log "Processing ACR: $ACR_NAME (RG: $ACR_RG, Sub: $SOURCE_SUB)"

  # Build the ACR resource ID
  ACR_ID="/subscriptions/${SOURCE_SUB}/resourceGroups/${ACR_RG}/providers/Microsoft.ContainerRegistry/registries/${ACR_NAME}"

  # ------ Step 1: Switch to destination subscription ------
  log "  Setting active subscription to: $DEST_SUBSCRIPTION"
  run "az account set --subscription '$DEST_SUBSCRIPTION'"

  # ------ Step 2: Ensure destination resource group exists ------
  log "  Ensuring resource group '$DEST_RG_NAME' exists..."
  run "az group show --name '$DEST_RG_NAME' --subscription '$DEST_SUBSCRIPTION' \
    --output none 2>/dev/null || \
    az group create --name '$DEST_RG_NAME' --location '$LOCATION' \
      --subscription '$DEST_SUBSCRIPTION' --output none"

  # ------ Step 3: Create the private endpoint ------
  log "  Creating private endpoint: $PE_NAME"
  if run "az network private-endpoint create \
      --name '$PE_NAME' \
      --resource-group '$DEST_RG_NAME' \
      --location '$LOCATION' \
      --subnet '$SUBNET_ID' \
      --private-connection-resource-id '$ACR_ID' \
      --group-id 'registry' \
      --connection-name '$CONN_NAME' \
      --output none"; then
    ok "  Private endpoint '$PE_NAME' created."
  else
    err "  Failed to create private endpoint for $ACR_NAME."
    FAILED=$((FAILED + 1))
    continue
  fi

  # ------ Step 4: Create DNS Zone Group (links PE to DNS Zone) ------
  DNS_GROUP_NAME="dzg-${ACR_NAME}"
  log "  Creating DNS zone group: $DNS_GROUP_NAME"
  if run "az network private-endpoint dns-zone-group create \
      --name '$DNS_GROUP_NAME' \
      --resource-group '$DEST_RG_NAME' \
      --endpoint-name '$PE_NAME' \
      --private-dns-zone '$DNS_ZONE_ID' \
      --zone-name 'privatelink.azurecr.io' \
      --output none"; then
    ok "  DNS zone group '$DNS_GROUP_NAME' created."
  else
    err "  Failed to create DNS zone group for $ACR_NAME."
    FAILED=$((FAILED + 1))
    continue
  fi

  SUCCESS=$((SUCCESS + 1))
  ok "  ✔ Done: $ACR_NAME"

done

# ---------- Summary ----------
log "======================================================"
log " Summary"
log "======================================================"
log "  Total processed : $TOTAL"
ok "  Succeeded       : $SUCCESS"
[[ $FAILED -gt 0 ]] && err "  Failed          : $FAILED" || log "  Failed          : 0"
log "  Log file        : $LOG_FILE"
log "======================================================"
